generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  pin       String?
  role      String   @default("USER")

  @@map("users")
}

enum Role {
  USER
  REQUESTER
  APPROVER
  CHECKER
  ADMIN
}
